generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  role            Role     @default(EMPLOYEE)
  positionId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Connected accounts for notifications
  lineUserId      String?  @unique // LINE user ID (for sending messages via LINE Messaging API)
  lineDisplayName String?          // LINE display name shown in profile

  // Notification preferences
  notifyEmail     Boolean  @default(true)
  notifyLine      Boolean  @default(false)

  position      Position?            @relation(fields: [positionId], references: [id])
  groupMembers  GroupMember[]
  progress      LessonProgress[]
  topicProgress LessonTopicProgress[]
  quizAttempts  QuizAttempt[]
}

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  permissions LessonPermission[]
}

model GroupMember {
  id      String @id @default(cuid())
  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String   @default("BookOpen")
  color       String   @default("#6366f1")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons Lesson[]
}

model Lesson {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String       @db.Text
  summary     String?
  categoryId  String
  status      LessonStatus @default(DRAFT)
  order       Int          @default(0)
  readMinutes Int          @default(5)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id])
  permissions       LessonPermission[]
  progress          LessonProgress[]
  positionTemplates PositionLesson[]
  topics            LessonTopic[]
  attachments       LessonAttachment[]
  changelog         LessonChangelog[]
  quiz              LessonQuiz?
  versions          LessonVersion[]
}

model LessonVersion {
  id          String       @id @default(cuid())
  lessonId    String
  version     Int
  title       String
  slug        String
  content     String       @db.Text
  summary     String?
  readMinutes Int
  categoryId  String
  status      LessonStatus
  savedById   String
  savedByName String
  note        String?      // optional description of what changed
  createdAt   DateTime     @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, version])
}

model LessonChangelog {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  userName  String
  summary   String   // human-readable description of what changed
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonAttachment {
  id                String    @id @default(cuid())
  lessonId          String
  type              BlockType
  url               String    // SharePoint share link
  fileName          String    // original file name
  fileSize          Int?      // bytes
  order             Int       @default(0)
  sharePointItemId  String?   // Graph API drive item ID (for deletion)
  sharePointDriveId String?   // Graph API drive ID (for deletion)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonTopic {
  id           String   @id @default(cuid())
  lessonId     String
  title        String
  order        Int      @default(0)
  mustComplete Boolean  @default(false) // if true, user must complete previous topics first
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson   Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  blocks   TopicBlock[]
  progress LessonTopicProgress[]
}

model TopicBlock {
  id       String    @id @default(cuid())
  topicId  String
  type     BlockType
  content  String    @db.Text // HTML for TEXT; URL or /uploads/... path for files
  caption  String?
  fileName String?   // original file name shown to user
  order    Int       @default(0)

  topic LessonTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model LessonTopicProgress {
  id          String    @id @default(cuid())
  userId      String
  topicId     String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic LessonTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

enum BlockType {
  TEXT
  IMAGE
  VIDEO
  PDF
  PPT
  EXCEL
  YOUTUBE
}

model LessonPermission {
  id       String @id @default(cuid())
  lessonId String
  groupId  String

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([lessonId, groupId])
}

model LessonProgress {
  id               String    @id @default(cuid())
  userId           String
  lessonId         String
  completedAt      DateTime?
  timeSpentSeconds Int       @default(0)
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Position Training Templates ──────────────────────────────────────────────

model Position {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users   User[]
  lessons PositionLesson[]
}

model PositionLesson {
  id         String @id @default(cuid())
  positionId String
  lessonId   String
  order      Int    @default(0)

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([positionId, lessonId])
}

// ─── Quiz ─────────────────────────────────────────────────────────────────────

model LessonQuiz {
  id         String   @id @default(cuid())
  lessonId   String   @unique
  passScore  Int      @default(80) // percentage required to pass (0–100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  text          String
  order         Int          @default(0)
  allowMultiple Boolean      @default(false) // true = multiple correct answers allowed
  mediaUrl      String?      // optional image or video URL shown with question
  mediaType     String?      // "IMAGE" | "VIDEO" | "YOUTUBE"
  choices       QuizChoice[]

  quiz LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizChoice {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int      // percentage 0–100
  passed      Boolean
  answers     Json     // { questionId: choiceId }
  createdAt   DateTime @default(now())

  quiz LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}
